# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=re_your_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Stripe Price IDs (create in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_your_pro_monthly_id
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_id

# Inngest (drip email campaigns)
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Sending domain for emails (defaults to venture-os.co)
SENDING_DOMAIN=venture-os.co

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
